# Firebase (frontend-facing keys — safe to expose)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin (server-side — KEEP SECRET)
FIREBASE_PROJECT_ID=your-project-id
# For production, generate a service account key from Firebase Console
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# Gemini AI (KEEP SECRET)
GOOGLE_GENAI_API_KEY=your_gemini_api_key

# Stripe (KEEP SECRET)
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRO_PRICE_ID=price_xxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxx

# App config
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
DOCKER_IMAGE=latex-editor-custom
